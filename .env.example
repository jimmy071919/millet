# Copy this file to .env and fill in your local values.
# .env is git-ignored; do not commit real tokens.

# Hugging Face token for pyannote speaker diarization.
# Required only if you want speaker diarization.
HF_TOKEN=hf_your_token_here

# Local model/cache/output paths. Relative paths are resolved from this project root.
MILLET_MODEL_CACHE_DIR=.millet-models
MILLET_RECORDINGS_DIR=millet-output

# LM Studio OpenAI-compatible server.
MILLET_SUMMARY_BACKEND=openai
MILLET_OPENAI_BASE_URL=http://localhost:1234/v1
MILLET_SUMMARY_MODEL=your-lm-studio-model-name
MILLET_OPENAI_API_KEY=not-needed

# Optional: if you still use legacy MEETSCRIBE_* variables elsewhere,
# millet supports them too, but MILLET_* is preferred in this repo.
